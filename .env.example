COMPOSE_PROJECT_NAME=vufind

# Public HTTP port for VuFind.
VUFIND_WEB_PORT=8888

# Local MariaDB port. Bound to 127.0.0.1 only.
VUFIND_DB_PORT=3307

# Required: external Solr base URL.
# Example: http://solr.example.org:8983/solr
SOLR_EXTERNAL_URL=

# VuFind checkout. The helper script clones ./vufind when it is missing.
VUFIND_REPO_URL=https://github.com/LA-Referencia-IOI/vufind
VUFIND_REF=v11.0.1

# VuFind runtime settings.
# Leave empty to derive http://localhost:${VUFIND_WEB_PORT} in vufind.sh.
VUFIND_SITE_URL=
VUFIND_THEME=bootstrap5
VUFIND_LOCAL_MODULES=
VUFIND_ENV=production
VUFIND_SYSTEM_DEBUG=false
VUFIND_NOILS_MODE=ils-none

# PHP error visibility.
VUFIND_PHP_DISPLAY_ERRORS=0
VUFIND_PHP_DISPLAY_STARTUP_ERRORS=0
VUFIND_PHP_ERROR_REPORTING=E_ALL
VUFIND_PHP_HTML_ERRORS=0

# MariaDB settings.
VUFIND_DB_NAME=vufind
VUFIND_DB_USER=vufind
VUFIND_DB_PASSWORD=vufind
VUFIND_DB_ROOT_PASSWORD=root

# Container resource hints used by Docker Compose.
VUFIND_MEM_LIMIT=512M
VUFIND_CPU_LIMIT=0.5
